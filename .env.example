# GitHub personal access token used to read PRs and post review comments.
GITHUB_TOKEN=

# Agent runtime: "cli" (Claude Code CLI / Max plan) or "sdk".
WARREN_RUNTIME=cli

# Comma-separated list of repos to watch, e.g. owner/repo,owner/other.
WARREN_REPOS=

# HTTP server bind config.
PORT=5000
HOST=0.0.0.0
