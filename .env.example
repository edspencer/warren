# ─── Credentials (server-side only; NEVER exposed to the review agent) ───

# GitHub token used to read PRs and post reviews in the default `pat` auth mode.
# Needs `repo` (or fine-grained Pull requests: read+write + Contents: read) on the
# repos you watch. REQUIRED for GitHub reviews in pat mode; not needed for
# `review-local` or when using GitHub App auth (below).
GITHUB_TOKEN=

# ─── GitHub App auth (optional; alternative to the PAT above) ───
# Set github.auth: app in .warren.yaml (or GITHUB_AUTH_MODE=app) to post as a bot
# (`<app-slug>[bot]`) with short-lived per-installation tokens. See the README
# "GitHub App identity" section for the one-time registration + install steps.

# Override .warren.yaml's github.auth (pat|app). Optional.
GITHUB_AUTH_MODE=
# The GitHub App's numeric App ID and the installation id (NOT secrets). May also
# be set in .warren.yaml (github.app_id / github.installation_id).
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# The App PRIVATE KEY, PEM text (SECRET). Provide EITHER this env var OR a mounted
# file via github.private_key_path in .warren.yaml. PKCS#1 (GitHub's default) and
# PKCS#8 are both accepted. Never commit this.
GITHUB_APP_PRIVATE_KEY=
# Optional: force Warren's bot login (else auto-resolved from GET /app in app mode).
GITHUB_BOT_LOGIN=

# ─── Webhook (optional) ───
# Shared secret for verifying GitHub webhook deliveries (X-Hub-Signature-256).
# When set, Warren exposes POST /webhook and rejects unsigned/invalid deliveries.
WARREN_WEBHOOK_SECRET=

# Anthropic API key. ONLY used when WARREN_RUNTIME=sdk. Leave unset when running
# on the Claude Code CLI / Max plan (runtime=cli).
ANTHROPIC_API_KEY=

# ─── Runtime ───

# Agent runtime: "cli" (Claude Code CLI / Max plan — default) or "sdk" (metered
# API, needs ANTHROPIC_API_KEY).
WARREN_RUNTIME=cli

# Post for real. Unset/0 = dry-run (reads GitHub, captures would-be writes to
# ${WARREN_DATA_DIR}, never posts). Set to 1/true to go live.
WARREN_LIVE=0

# ─── What to watch ───

# Comma-separated repos to watch, e.g. owner/repo,owner/other. Merged with any
# `repos:` in .warren.yaml.
WARREN_REPOS=

# ─── HTTP server (dashboard + /status + manual-enqueue API) ───

PORT=5000          # or WARREN_PORT; WARREN_PORT wins if both are set
HOST=0.0.0.0       # or WARREN_HOST

# Base dir for JSON state, review history, and captured dry-run payloads.
WARREN_DATA_DIR=./data

# ─── Dashboard auth ───

# "none" (default; open — for a trusted LAN) or "jwt" (require a signed
# `Authorization: Bearer <jwt>` on /api/*).
WARREN_AUTH_MODE=none

# jwt mode only: HS256 shared secret used to verify tokens. REQUIRED when
# WARREN_AUTH_MODE=jwt (Warren refuses to start without it).
WARREN_JWT_SECRET=

# jwt mode, optional: expected `iss` / `aud` claims (validated when set).
WARREN_JWT_ISSUER=
WARREN_JWT_AUDIENCE=
