{
  "name": "warren",
  "version": "0.3.0",
  "private": true,
  "description": "Self-hosted, agentic AI code-review bot for GitHub PRs, built on the Claude Agent SDK. A CodeRabbit alternative that runs on your own Claude Max plan at ~zero marginal cost.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "code-review",
    "github",
    "pull-request",
    "claude",
    "anthropic",
    "agent",
    "claude-agent-sdk",
    "ai",
    "coderabbit",
    "self-hosted",
    "bot"
  ],
  "homepage": "https://github.com/edspencer/warren#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edspencer/warren.git"
  },
  "bugs": {
    "url": "https://github.com/edspencer/warren/issues"
  },
  "author": "Ed Spencer",
  "bin": {
    "warren": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "review:local": "tsx src/index.ts review-local",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "changeset": "changeset",
    "changeset:version": "changeset version && npm install --package-lock-only"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "@herdctl/core": "^5.18.2",
    "fastify": "^5.0.0",
    "jose": "^6.2.3",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
